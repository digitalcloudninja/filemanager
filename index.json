{
    "openapi": "3.1.0",
    "info": {
        "title": "File Management API",
        "description": "A file management API for container applications",
        "contact": {
            "email": "developer@example.com"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "https://www.apache.org/licenses/LICENSE-2.0"
        },
        "version": "v1"
    },
    "servers": [
        {
            "url": "http://localhost:{port}/v1/api",
            "description": "Beta",
            "variables": {
                "port": {
                    "default": "8082"
                }
            }
        },
        {
            "url": "http://localhost/v1/api",
            "description": "Production"
        }
    ],
    "security": [
        {
            "basicAuth": []
        },
        {
            "APIKey": []
        }
    ],
    "tags": [
        {
            "name": "Files",
            "description": "Operations for working with stored files."
        }
    ],
    "paths": {
        "/filemanager/upload": {
            "put": {
                "tags": [
                    "Files"
                ],
                "summary": "Upload a File",
                "operationId": "uploadFile",
                "requestBody": {
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "File": {
                                        "type": "string",
                                        "format": "binary"
                                    }
                                },
                                "required": [
                                    "File"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Returns the newly created file resource",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/File",
                                    "example": {
                                        "name": "example.csv",
                                        "type": "text/csv",
                                        "size": 1024,
                                        "_links": {
                                            "self": "https://api.example.com/v1/api/filemanager/a9effbb3-4178-f6e9-08a7-e9520c4620d7"
                                        }
                                    }
                                }
                            },
                            "application/hal+json": {
                                "schema": {
                                    "$ref": "#/components/schemas/File",
                                    "example": {
                                        "name": "example.csv",
                                        "type": "text/csv",
                                        "size": 1024,
                                        "_links": {
                                            "self": "https://api.example.com/v1/api/filemanager/a9effbb3-4178-f6e9-08a7-e9520c4620d7"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Returned when your request is not valid",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ProblemDetail"
                                }
                            },
                            "application/hal+json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ProblemDetail"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/filemanager/{id}": {
            "get": {
                "tags": [
                    "Files"
                ],
                "summary": "View a File",
                "operationId": "getFile",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "404": {
                        "description": "Returned when the file is not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ProblemDetail"
                                }
                            },
                            "application/hal+json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ProblemDetail"
                                }
                            }
                        }
                    },
                    "200": {
                        "description": "Returns the file, with the Content-Type set to the content of the file.",
                        "content": {
                            "application/json": {
                                "schema": {}
                            },
                            "application/hal+json": {
                                "schema": {}
                            }
                        }
                    },
                    "400": {
                        "description": "Returned when the id is invalid",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ProblemDetail"
                                }
                            },
                            "application/hal+json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ProblemDetail"
                                }
                            }
                        }
                    }
                }
            },
            "delete": {
                "tags": [
                    "Files"
                ],
                "summary": "Delete a File",
                "operationId": "deleteFile",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "404": {
                        "description": "Returned when the file is not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ProblemDetail"
                                }
                            },
                            "application/hal+json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ProblemDetail"
                                }
                            }
                        }
                    },
                    "200": {
                        "description": "Successfully deleted."
                    },
                    "400": {
                        "description": "Returned when the id is invalid",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ProblemDetail"
                                }
                            },
                            "application/hal+json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ProblemDetail"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/filemanager/list": {
            "get": {
                "tags": [
                    "Files"
                ],
                "summary": "List All Files",
                "operationId": "getAllFiles",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Zero-based page index (0..N)",
                        "required": false,
                        "schema": {
                            "default": 0,
                            "minimum": 0
                        }
                    },
                    {
                        "name": "size",
                        "in": "query",
                        "description": "The size of the page to be returned",
                        "required": false,
                        "schema": {
                            "default": 20,
                            "minimum": 1
                        }
                    },
                    {
                        "name": "sort",
                        "in": "query",
                        "description": "Sorting criteria in the format: property,(asc|desc). Default sort order is ascending. Multiple sort criteria are supported.",
                        "required": false,
                        "schema": {
                            "items": {}
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success: Returns a list of files",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PagedModel",
                                    "example": {
                                        "_embedded": {
                                            "files": [
                                                {
                                                    "name": "example.csv",
                                                    "content-type": "text/csv",
                                                    "size": 315,
                                                    "_links": {
                                                        "self": {
                                                            "href": "http://api.example.com/v1/api/filemanager/6f30d7a5-2f2f-444b-965b-9dd5798e2f8c"
                                                        }
                                                    }
                                                }
                                            ]
                                        },
                                        "_links": {
                                            "self": {
                                                "href": "http://api.example.com/v1/api/filemanager/list?page=0&size=20"
                                            }
                                        },
                                        "page": {
                                            "size": 20,
                                            "totalElements": 1,
                                            "totalPages": 1,
                                            "number": 0
                                        }
                                    }
                                }
                            },
                            "application/hal+json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PagedModel",
                                    "example": {
                                        "_embedded": {
                                            "files": [
                                                {
                                                    "name": "example.csv",
                                                    "content-type": "text/csv",
                                                    "size": 315,
                                                    "_links": {
                                                        "self": {
                                                            "href": "http://api.example.com/v1/api/filemanager/6f30d7a5-2f2f-444b-965b-9dd5798e2f8c"
                                                        }
                                                    }
                                                }
                                            ]
                                        },
                                        "_links": {
                                            "self": {
                                                "href": "http://api.example.com/v1/api/filemanager/list?page=0&size=20"
                                            }
                                        },
                                        "page": {
                                            "size": 20,
                                            "totalElements": 1,
                                            "totalPages": 1,
                                            "number": 0
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/filemanager/download/{id}": {
            "get": {
                "tags": [
                    "Files"
                ],
                "summary": "Download a File",
                "operationId": "downloadFile",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "404": {
                        "description": "Returned when the file is not found",
                        "content": {
                            "application/octet-stream": {
                                "schema": {
                                    "$ref": "#/components/schemas/ProblemDetail"
                                }
                            }
                        }
                    },
                    "200": {
                        "description": "Returns the file.",
                        "content": {
                            "application/octet-stream": {
                                "schema": {}
                            }
                        }
                    },
                    "400": {
                        "description": "Returned when the id is invalid",
                        "content": {
                            "application/octet-stream": {
                                "schema": {
                                    "$ref": "#/components/schemas/ProblemDetail"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "File": {
                "description": "A file descriptor.",
                "properties": {
                    "id": {
                        "type": "string",
                        "format": "uuid",
                        "description": "The file's unique identifier",
                        "example": "a9effbb3-4178-f6e9-08a7-e9520c4620d7"
                    },
                    "name": {
                        "type": "string",
                        "description": "The file's original name",
                        "example": "example.csv",
                        "maxLength": 50,
                        "minLength": 0
                    },
                    "content-type": {
                        "type": "string",
                        "description": "The file's content-type.",
                        "example": "text/csv",
                        "maxLength": 50,
                        "minLength": 0
                    },
                    "size": {
                        "type": "integer",
                        "format": "int64",
                        "description": "The file's size in bytes",
                        "example": 0
                    },
                    "links": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Link"
                        }
                    }
                },
                "required": [
                    "content-type",
                    "name"
                ]
            },
            "Link": {
                "properties": {
                    "rel": {
                        "type": "string"
                    },
                    "href": {
                        "type": "string"
                    },
                    "hreflang": {
                        "type": "string"
                    },
                    "media": {
                        "type": "string"
                    },
                    "title": {
                        "type": "string"
                    },
                    "type": {
                        "type": "string"
                    },
                    "deprecation": {
                        "type": "string"
                    },
                    "profile": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    }
                }
            },
            "ProblemDetail": {
                "properties": {
                    "type": {
                        "type": "string",
                        "format": "uri"
                    },
                    "title": {
                        "type": "string"
                    },
                    "status": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "detail": {
                        "type": "string"
                    },
                    "instance": {
                        "type": "string",
                        "format": "uri"
                    },
                    "properties": {
                        "type": "object",
                        "additionalProperties": {}
                    }
                }
            },
            "PageMetadata": {
                "properties": {
                    "size": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "totalElements": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "totalPages": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "number": {
                        "type": "integer",
                        "format": "int64"
                    }
                }
            },
            "PagedModel": {
                "properties": {
                    "links": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Link"
                        }
                    },
                    "content": {
                        "type": "array",
                        "items": {}
                    },
                    "page": {
                        "$ref": "#/components/schemas/PageMetadata"
                    }
                }
            }
        },
        "securitySchemes": {
            "APIKey": {
                "type": "apiKey",
                "name": "APIKey",
                "in": "header"
            },
            "basicAuth": {
                "type": "http",
                "scheme": "basic"
            }
        }
    }
}